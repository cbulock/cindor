{
  "name": "emberline-ui-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run generate:wrappers && npm run build --workspace emberline-ui-core && npm run build --workspace emberline-ui-react && npm run build --workspace emberline-ui-vue",
    "generate:wrappers": "node scripts/generate-framework-wrappers.mjs",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:one": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@types/node": "^24.9.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.25.1",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "lit": "^3.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.3.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1",
    "vue": "^3.5.13",
    "playwright": "^1.59.1",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1"
  }
}
